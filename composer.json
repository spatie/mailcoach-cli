{
    "name": "spatie/mailcoach-cli",
    "description": "CLI tool for interacting with the Mailcoach API",
    "keywords": ["mailcoach", "cli", "api"],
    "homepage": "https://github.com/spatie/mailcoach-cli",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/spatie/mailcoach-cli/issues",
        "source": "https://github.com/spatie/mailcoach-cli"
    },
    "authors": [
        {
            "name": "Spatie",
            "email": "info@spatie.be",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "laravel-zero/framework": "^12.0",
        "spatie/laravel-openapi-cli": "^1.0",
        "illuminate/http": "^12.0",
        "pestphp/pest": "^3.8|^4.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.25",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Spatie\\MailcoachCli\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Spatie\\MailcoachCli\\MailcoachSkillsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["builds/mailcoach"]
}
